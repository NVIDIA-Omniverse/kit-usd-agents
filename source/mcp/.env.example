# MCP Servers Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file with real API keys!

# ==============================================================================
# Required: NVIDIA API Key
# ==============================================================================
# Get from: https://build.nvidia.com
# Used for: LLM access and cloud-based embeddings/reranking (NGC API mode)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# Optional: NGC API Key (for Local NIM Deployment)
# ==============================================================================
# Get from: https://ngc.nvidia.com
# Used for: Pulling NIM container images for local embedder/reranker
# Only needed if using docker-compose.local.yaml
NGC_API_KEY=

# ==============================================================================
# Optional: Port Overrides
# ==============================================================================
# Default ports: OmniUI=9901, Kit=9902, USD Code=9903, IsaacSim=9904
# Uncomment to override:
# MCP_PORT=9903

# ==============================================================================
# Optional: Local Embedder/Reranker Configuration
# ==============================================================================
# Use these to connect to external embedder/reranker services
# instead of NVIDIA API or local NIMs

# Set to 'local' to use external embedder/reranker services
# KIT_EMBEDDER_BACKEND=local
# KIT_LOCAL_EMBEDDER_URL=http://your-embedder-host:8001

# KIT_RERANKER_BACKEND=local
# KIT_LOCAL_RERANKER_URL=http://your-reranker-host:8002

# ==============================================================================
# Optional: Disable Usage Analytics
# ==============================================================================
# KIT_MCP_DISABLE_USAGE_LOGGING=true
# OMNI_UI_DISABLE_USAGE_LOGGING=true
